#!/usr/bin/env bash
set -euo pipefail

# Server provisioning script for yip.yip.yip.yip.yip.computer
# Run as root on a fresh Ubuntu 24.04 Linode

if [ "$(id -u)" -ne 0 ]; then
    echo "Error: Run this script as root"
    exit 1
fi

echo "==> Installing Docker"
apt-get update
apt-get install -y ca-certificates curl gnupg
install -m 0755 -d /etc/apt/keyrings
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
chmod a+r /etc/apt/keyrings/docker.gpg

echo \
  "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu \
  $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | \
  tee /etc/apt/sources.list.d/docker.list > /dev/null

apt-get update
apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

systemctl enable docker
systemctl start docker

echo "==> Configuring UFW"
ufw allow 22/tcp
ufw allow 80/tcp
ufw allow 443/tcp
ufw --force enable

echo "==> Installing fail2ban"
apt-get install -y fail2ban
systemctl enable fail2ban
systemctl start fail2ban

echo "==> Creating data directories"
mkdir -p /root/yipyip/data/backups

echo "==> Setting up backup cron (daily 03:00 UTC)"
cat > /etc/cron.d/yipyip-backup <<'CRON'
# yip.yip.yip.yip.yip.computer daily database backup
0 3 * * * root /root/yipyip/bin/backup >> /var/log/yipyip-backup.log 2>&1
CRON
chmod 644 /etc/cron.d/yipyip-backup

echo "==> Setting up cleanup cron (daily 04:00+ UTC)"
cat > /etc/cron.d/yipyip-cleanup <<'CRON'
# yip.yip.yip.yip.yip.computer ephemeral cleanup (7 days)
0 4 * * * root cd /root/yipyip && docker compose exec -T web tootctl statuses remove --days=7 >> /var/log/yipyip-cleanup.log 2>&1
30 4 * * * root cd /root/yipyip && docker compose exec -T web tootctl media remove --days=7 >> /var/log/yipyip-cleanup.log 2>&1
45 4 * * * root cd /root/yipyip && docker compose exec -T web tootctl preview_cards remove --days=7 >> /var/log/yipyip-cleanup.log 2>&1
CRON
chmod 644 /etc/cron.d/yipyip-cleanup

echo ""
echo "==> Setup complete. Next steps:"
echo ""
echo "  1. cp .env.production.example .env.production"
echo "  2. cp .env.certbot.example .env.certbot"
echo "  3. Edit both files with real values"
echo "  4. Generate secrets (see README.md)"
echo "  5. Obtain SSL certificate (see README.md)"
echo "  6. docker compose run --rm web bundle exec rake db:setup"
echo "  7. docker compose up -d"
echo "  8. Create admin account (see README.md)"
echo ""
