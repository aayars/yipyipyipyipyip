# Instance
LOCAL_DOMAIN=yip.yip.yip.yip.yip.computer
SINGLE_USER_MODE=false
# Federation is blocked at nginx level (see nginx.conf).
# Do NOT set LIMITED_FEDERATION_MODE=true — it hides all content from unauthenticated visitors.
AUTHORIZED_FETCH=true

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=mastodon
DB_USER=mastodon
DB_PASS=changeme_generate_a_real_password
POSTGRES_PASSWORD=changeme_generate_a_real_password

# Secrets (generate with: docker compose run --rm web bundle exec rake secret)
SECRET_KEY_BASE=
OTP_SECRET=

# Web Push (generate with: docker compose run --rm web bundle exec rake mastodon:webpush:generate_vapid_key)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Media storage (local disk, no S3)
S3_ENABLED=false

# SMTP (AWS SES)
SMTP_SERVER=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_LOGIN=
SMTP_PASSWORD=
SMTP_AUTH_METHOD=plain
SMTP_OPENSSL_VERIFY_MODE=peer
SMTP_ENABLE_STARTTLS=auto
SMTP_FROM_ADDRESS=noreply@yip.computer

# Locale
DEFAULT_LOCALE=en
